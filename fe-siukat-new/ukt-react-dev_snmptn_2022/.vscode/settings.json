{
  "editor.tabSize": 4,
  "editor.formatOnSave": true,
  "editor.detectIndentation": false,
  "javascript.preferences.quoteStyle": "single",
  "files.eol": "\r\n",
  "[javascript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "search.exclude": {
    "**/.yarn": true,
    "**/.pnp.*": true
  },
  "eslint.nodePath": ".yarn/sdks"
}
